# ===========================================================================
# The CivicX — environment configuration template.
# Copy to .env and fill in real values:  cp .env.example .env
# Generate strong secrets with:           ./scripts/generate-secrets.sh
# NEVER commit your real .env (it is gitignored).
# ===========================================================================

# --- Database Credentials ---
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_strong_db_password
DB_HOST=postgres
DB_PORT=5432

# --- MinIO Object Storage Credentials ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_minio_password
MINIO_ENDPOINT=http://minio:9000
# Public URL the browser uses to load uploaded media (your domain in prod)
MINIO_PUBLIC_URL=http://localhost:9000

# --- Redis / RabbitMQ / Elasticsearch (internal docker network) ---
REDIS_URL=redis://redis:6379
RABBITMQ_URL=amqp://rabbitmq:5672
ELASTICSEARCH_URL=http://elasticsearch:9200

# --- Authentication / Security ---
# Master switch: when true, services require valid JWTs on protected routes.
AUTH_REQUIRED=true
# Secret used to sign JWTs. MUST be long & random. Generate with the script.
JWT_SECRET=CHANGE_ME_generate_a_64_char_random_secret
JWT_EXPIRY_SECONDS=604800
# DEV_MODE=true exposes OTP codes in API responses. Keep false in production.
DEV_MODE=false
# ALLOW_MOCK_AUTH=true trusts client-supplied OAuth payloads (dev only).
# Set false in production and configure GOOGLE_CLIENT_ID below.
ALLOW_MOCK_AUTH=false

# --- Google OAuth (production sign-in) ---
# Create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# --- Admin panel credentials ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# --- SMS / OTP provider (Twilio). Leave blank to disable SMS delivery. ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- CORS: browser origins allowed to call the API gateway ---
CORS_ORIGINS=http://localhost:3000,http://localhost:3005

# --- Public API URL baked into the frontends at build time ---
# In production set this to your gateway's public URL, e.g. https://api.example.com
PUBLIC_API_URL=http://localhost:8000
